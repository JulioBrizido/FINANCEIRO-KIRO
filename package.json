{
  "name": "financeiro-facil",
  "version": "1.0.0",
  "description": "Sistema de controle financeiro pessoal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist-installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.financeiro.facil",
    "productName": "Financeiro Fácil",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "dashboard.html",
      "config.html",
      "db.js"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.png",
      "uninstallerIcon": "icon.png",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Financeiro Fácil"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
